spring.application.name=securevault-api

spring.datasource.url=jdbc:postgresql://localhost:5432/securevault
spring.datasource.username=postgres
spring.datasource.password=YOUR_DATABASE_PASSWORD
spring.jpa.hibernate.ddl-auto=create-drop

# Add your secret here (Must be at least 256-bit / 32-bytes)
app.jwt.secret=YOUR_64_CHARACTER_HEX_SIGNING_KEY_HERE
spring.docker.compose.enabled=false